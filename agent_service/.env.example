# Copy this file to .env and fill in real values. .env is gitignored.

# --- LLM provider selection -------------------------------------------------
# Which provider the llm/ facade routes to. One of: gemini, groq, ollama
LLM_PROVIDER=gemini

# --- Google Gemini (primary, free tier) -------------------------------------
# Get a free API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Groq (optional fallback, free tier) ------------------------------------
# Get a free API key from https://console.groq.com
GROQ_API_KEY=

# --- Ollama (optional offline fallback) -------------------------------------
# Default works if Ollama is running locally. Override only if you moved it.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:32b

# --- GenMail backend --------------------------------------------------------
GENMAIL_API_URL=http://localhost:5000

# --- Agent service ----------------------------------------------------------
AGENT_SERVICE_PORT=5001
LOG_DB_PATH=logs.db

# --- LLM rate limiting ------------------------------------------------------
# Max concurrent LLM calls. Free tiers are tight (Gemini Flash = 5 RPM),
# so keep this low. Bump to 5+ on Groq or paid Gemini.
LLM_MAX_CONCURRENCY=2
